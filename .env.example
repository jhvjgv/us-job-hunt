# API（Java 后端，须带 /api）
# VITE_API_URL=/api

# —— 双域名（同一 dist，Nginx 两个 server_name 指向同一 root）——
# 本地开发若不使用 member.* / job.* 子域，可强制入口：
# VITE_SITE_ENTRY=member   # 预览 $1 站
# VITE_SITE_ENTRY=job      # 预览 $39 站（默认 localhost 视为 job）
VITE_SITE_ENTRY=

VITE_MEMBER_SITE_ORIGIN=https://member.athenaprogramming.com
VITE_JOB_SITE_ORIGIN=https://job.athenaprogramming.com

# —— 结账入口 ——
# $1：member 站固定站内 /price（无需外部 URL）

# $39：job 站 Join / 按钮（可选外部结账，不填则走站内 /pricing）
VITE_FULL_PROGRAM_CHECKOUT_URL=
